{
  "openapi": "3.0.0",
  "info": {
    "title": "Riot API",
    "description": "Upstream description"
  },
  "servers": [
    {
      "url": "https://{platform}.api.riotgames.com",
      "variables": {
        "platform": {
          "default": "na1",
          "enum": ["europe", "na1"]
        }
      }
    }
  ],
  "security": [
    {
      "api_key": []
    }
  ],
  "components": {
    "securitySchemes": {
      "api_key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Riot-Token"
      }
    }
  },
  "paths": {
    "/riot/account/v1/accounts/me": {
      "get": {
        "operationId": "getAccount",
        "security": [
          {
            "api_key": []
          }
        ],
        "parameters": [
          {
            "name": "existing",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
